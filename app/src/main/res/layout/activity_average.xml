<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:fitsSystemWindows="true">

        <!-- ═══════════════ HEADER ═══════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:background="#1A1D2E">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹ Menú"
                android:textColor="#8892B0"
                android:textSize="15sp"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Promedio"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="4dp"
                app:layout_constraintBottom_toTopOf="@+id/tvSubtitle"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Promedio ponderado del estudiante"
                android:textColor="#8892B0"
                android:textSize="13sp"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ═══════════════ CONTENIDO ═══════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Card: Nombre -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1D2E"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="14dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ESTUDIANTE"
                        android:textColor="#64FFDA"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <EditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Nombre completo"
                        android:textColorHint="#3A3F5A"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:inputType="textPersonName"
                        android:background="@drawable/input_bg"
                        android:paddingHorizontal="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Notas -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1D2E"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="14dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NOTAS  (escala 0 – 10)"
                        android:textColor="#64FFDA"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- ── Nota 1 ── -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <TextView android:id="@+id/badge1"
                            android:layout_width="52dp" android:layout_height="52dp"
                            android:gravity="center" android:text="15%"
                            android:textColor="#64FFDA" android:textSize="12sp" android:textStyle="bold"
                            android:background="@drawable/badge_bg"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:text="Tarea" android:textColor="#CCD6F6" android:textSize="15sp"
                            android:layout_marginStart="12dp"
                            app:layout_constraintStart_toEndOf="@id/badge1"
                            app:layout_constraintEnd_toStartOf="@id/etNota1"
                            app:layout_constraintTop_toTopOf="@id/etNota1"
                            app:layout_constraintBottom_toBottomOf="@id/etNota1"/>
                        <EditText android:id="@+id/etNota1"
                            android:layout_width="80dp" android:layout_height="52dp"
                            android:hint="—" android:textColorHint="#3A3F5A"
                            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                            android:gravity="center" android:inputType="numberDecimal"
                            android:background="@drawable/input_bg"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- ── Nota 2 ── -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <TextView android:id="@+id/badge2"
                            android:layout_width="52dp" android:layout_height="52dp"
                            android:gravity="center" android:text="15%"
                            android:textColor="#64FFDA" android:textSize="12sp" android:textStyle="bold"
                            android:background="@drawable/badge_bg"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:text="Participación" android:textColor="#CCD6F6" android:textSize="15sp"
                            android:layout_marginStart="12dp"
                            app:layout_constraintStart_toEndOf="@id/badge2"
                            app:layout_constraintEnd_toStartOf="@id/etNota2"
                            app:layout_constraintTop_toTopOf="@id/etNota2"
                            app:layout_constraintBottom_toBottomOf="@id/etNota2"/>
                        <EditText android:id="@+id/etNota2"
                            android:layout_width="80dp" android:layout_height="52dp"
                            android:hint="—" android:textColorHint="#3A3F5A"
                            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                            android:gravity="center" android:inputType="numberDecimal"
                            android:background="@drawable/input_bg"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- ── Nota 3 ── -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <TextView android:id="@+id/badge3"
                            android:layout_width="52dp" android:layout_height="52dp"
                            android:gravity="center" android:text="20%"
                            android:textColor="#64FFDA" android:textSize="12sp" android:textStyle="bold"
                            android:background="@drawable/badge_bg"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:text="Laboratorio" android:textColor="#CCD6F6" android:textSize="15sp"
                            android:layout_marginStart="12dp"
                            app:layout_constraintStart_toEndOf="@id/badge3"
                            app:layout_constraintEnd_toStartOf="@id/etNota3"
                            app:layout_constraintTop_toTopOf="@id/etNota3"
                            app:layout_constraintBottom_toBottomOf="@id/etNota3"/>
                        <EditText android:id="@+id/etNota3"
                            android:layout_width="80dp" android:layout_height="52dp"
                            android:hint="—" android:textColorHint="#3A3F5A"
                            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                            android:gravity="center" android:inputType="numberDecimal"
                            android:background="@drawable/input_bg"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- ── Nota 4 ── -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <TextView android:id="@+id/badge4"
                            android:layout_width="52dp" android:layout_height="52dp"
                            android:gravity="center" android:text="25%"
                            android:textColor="#64FFDA" android:textSize="12sp" android:textStyle="bold"
                            android:background="@drawable/badge_bg"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:text="Examen Parcial" android:textColor="#CCD6F6" android:textSize="15sp"
                            android:layout_marginStart="12dp"
                            app:layout_constraintStart_toEndOf="@id/badge4"
                            app:layout_constraintEnd_toStartOf="@id/etNota4"
                            app:layout_constraintTop_toTopOf="@id/etNota4"
                            app:layout_constraintBottom_toBottomOf="@id/etNota4"/>
                        <EditText android:id="@+id/etNota4"
                            android:layout_width="80dp" android:layout_height="52dp"
                            android:hint="—" android:textColorHint="#3A3F5A"
                            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                            android:gravity="center" android:inputType="numberDecimal"
                            android:background="@drawable/input_bg"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- ── Nota 5 ── -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView android:id="@+id/badge5"
                            android:layout_width="52dp" android:layout_height="52dp"
                            android:gravity="center" android:text="25%"
                            android:textColor="#64FFDA" android:textSize="12sp" android:textStyle="bold"
                            android:background="@drawable/badge_bg"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:text="Examen Final" android:textColor="#CCD6F6" android:textSize="15sp"
                            android:layout_marginStart="12dp"
                            app:layout_constraintStart_toEndOf="@id/badge5"
                            app:layout_constraintEnd_toStartOf="@id/etNota5"
                            app:layout_constraintTop_toTopOf="@id/etNota5"
                            app:layout_constraintBottom_toBottomOf="@id/etNota5"/>
                        <EditText android:id="@+id/etNota5"
                            android:layout_width="80dp" android:layout_height="52dp"
                            android:hint="—" android:textColorHint="#3A3F5A"
                            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold"
                            android:gravity="center" android:inputType="numberDecimal"
                            android:background="@drawable/input_bg"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botones acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClear"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Limpiar"
                    android:textColor="#8892B0"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"
                    app:backgroundTint="#1A1D2E"
                    app:strokeColor="#2A3050"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCalculate"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="2"
                    android:text="Calcular Promedio"
                    android:textColor="#0F1117"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="#64FFDA"
                    app:cornerRadius="12dp"
                    style="@style/Widget.Material3.Button"/>

            </LinearLayout>

            <!-- Card: Resultado -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1D2E"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:alpha="0"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RESULTADO"
                        android:textColor="#64FFDA"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:id="@+id/tvNameResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#8892B0"
                        android:textSize="16sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvAverage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#FFFFFF"
                        android:textSize="80sp"
                        android:fontFamily="sans-serif-light"
                        android:layout_marginBottom="0dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="de 10.00"
                        android:textColor="#3A3F5A"
                        android:textSize="14sp"
                        android:layout_marginBottom="20dp"/>

                    <ProgressBar
                        android:id="@+id/progressBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#64FFDA"
                        android:progressBackgroundTint="#2A2F4A"
                        android:layout_marginBottom="20dp"/>

                    <TextView
                        android:id="@+id/tvState"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
