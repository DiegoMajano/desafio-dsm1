<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1117"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="700dp">

        <!-- ══════════ HEADER ══════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:background="#1A1D2E"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Círculo decorativo fondo -->
            <View
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:background="@drawable/circle_deco"
                android:alpha="0.06"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginEnd="-80dp"
                android:layout_marginBottom="-80dp"/>

            <!-- Segundo círculo -->
            <View
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/circle_deco"
                android:alpha="0.05"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginStart="-30dp"
                android:layout_marginTop="-30dp"/>

            <!-- Logo / ícono grande -->
            <ImageView
                android:id="@+id/tvLogoEmoji"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:gravity="center"
                android:src="@drawable/phone"
                android:textSize="36sp"
                android:background="@drawable/logo_bg"
                android:layout_marginStart="24dp"
                android:layout_marginTop="44dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:id="@+id/tvTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Desafío Práctico"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginStart="24dp"
                android:layout_marginTop="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvLogoEmoji"/>

            <TextView
                android:id="@+id/tvSubtitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="4dp"
                android:text="Desarrollo de Software para Móviles - DSM 03L"
                android:textColor="#8892B0"
                android:textSize="13sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTitulo" />

            <!-- Chip "Universidad Don Bosco" -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  Universidad Don Bosco  "
                android:textColor="#64FFDA"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:background="@drawable/chip_teal"
                android:layout_marginStart="24dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSubtitulo"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ══════════ LABEL SECCIÓN ══════════ -->
        <TextView
            android:id="@+id/tvSeccion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EJERCICIOS"
            android:textColor="#4A4F6A"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:layout_marginTop="22dp"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- ══════════ CARD EJ. 1 ══════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardEj1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1D2E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvSeccion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnAverage"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/card_ripple"
                android:paddingHorizontal="18dp">

                <!-- Ícono badge -->
                <ImageView
                    android:id="@+id/icon1"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/badge_teal"
                    android:gravity="center"
                    android:src="@drawable/notas"
                    android:textSize="18sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@android:color/white" />

                <!-- Textos -->
                <TextView
                    android:id="@+id/title1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Promedio del Estudiante"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintStart_toEndOf="@id/icon1"
                    app:layout_constraintEnd_toStartOf="@id/arrow1"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/sub1"/>

                <TextView
                    android:id="@+id/sub1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="5 notas ponderadas · Aprobado / Reprobado"
                    android:textColor="#8892B0"
                    android:textSize="12sp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintStart_toEndOf="@id/icon1"
                    app:layout_constraintEnd_toStartOf="@id/arrow1"
                    app:layout_constraintTop_toBottomOf="@id/title1"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <!-- Flecha -->
                <TextView
                    android:id="@+id/arrow1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#64FFDA"
                    android:textSize="26sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <!-- Número ejercicio -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="40dp"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="sans-serif-light"
                    android:text="01"
                    android:textColor="#2A3050"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════ CARD EJ. 2 ══════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardEj2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1D2E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/cardEj1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnDiscounts"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/card_ripple"
                android:paddingHorizontal="18dp">

                <ImageView
                    android:id="@+id/icon2"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:src="@drawable/money"
                    android:textSize="22sp"
                    android:background="@drawable/badge_gold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/title2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Descuentos al Salario"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintStart_toEndOf="@id/icon2"
                    app:layout_constraintEnd_toStartOf="@id/arrow2"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/sub2"/>

                <TextView
                    android:id="@+id/sub2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="AFP · ISSS · Renta por tramos"
                    android:textColor="#8892B0"
                    android:textSize="12sp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintStart_toEndOf="@id/icon2"
                    app:layout_constraintEnd_toStartOf="@id/arrow2"
                    app:layout_constraintTop_toBottomOf="@id/title2"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/arrow2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#FFD166"
                    android:textSize="26sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="02"
                    android:textColor="#2A3050"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-light"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginEnd="40dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════ CARD EJ. 3 ══════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardEj3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1A1D2E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/cardEj2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/btnCalculator"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/card_ripple"
                android:paddingHorizontal="18dp">

                <ImageView
                    android:id="@+id/icon3"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:src="@drawable/cal"
                    android:textSize="22sp"
                    android:background="@drawable/badge_orange"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/title3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Calculadora Básica"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintStart_toEndOf="@id/icon3"
                    app:layout_constraintEnd_toStartOf="@id/arrow3"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/sub3"/>

                <TextView
                    android:id="@+id/sub3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="+  −  ×  ÷  xⁿ  √  · Validaciones"
                    android:textColor="#8892B0"
                    android:textSize="12sp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintStart_toEndOf="@id/icon3"
                    app:layout_constraintEnd_toStartOf="@id/arrow3"
                    app:layout_constraintTop_toBottomOf="@id/title3"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:id="@+id/arrow3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textColor="#FF9F43"
                    android:textSize="26sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="03"
                    android:textColor="#2A3050"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-light"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginEnd="40dp"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════ FOOTER ══════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="172dp"
            android:text="Developed by Diego Rodríguez Majano RM220481"
            android:textColor="#2A3050"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardEj3" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
