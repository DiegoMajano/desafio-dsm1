<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1117"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:fitsSystemWindows="true">

        <!-- ═══════════════ HEADER ═══════════════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:background="#1A1D2E">

            <TextView
                android:id="@+id/btnBackSalary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="‹ Menú"
                android:textColor="#8892B0"
                android:textSize="15sp"
                android:padding="16dp"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvTitleSal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Salario Neto"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="4dp"
                app:layout_constraintBottom_toTopOf="@+id/tvSubtitleSal"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tvSubtitleSal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cálculo de descuentos AFP, ISSS y Renta"
                android:textColor="#8892B0"
                android:textSize="13sp"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="20dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ═══════════════ CONTENIDO ═══════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Card: Datos del empleado -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1D2E"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EMPLEADO"
                        android:textColor="#FFD166"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <EditText
                        android:id="@+id/etEmpName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Nombre completo"
                        android:textColorHint="#3A3F5A"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:inputType="textPersonName"
                        android:background="@drawable/input_bg"
                        android:paddingHorizontal="16dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Salario -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1D2E"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SALARIO BASE"
                        android:textColor="#FFD166"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <EditText
                        android:id="@+id/etSalaryBase"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="$ 0.00"
                        android:textColorHint="#3A3F5A"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:inputType="numberDecimal"
                        android:background="@drawable/input_bg"
                        android:paddingHorizontal="16dp"/>

                    <!-- Info descuentos -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="14dp">

                        <!-- AFP chip -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/chip_bg"
                            android:padding="10dp"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AFP"
                                android:textColor="#8892B0"
                                android:textSize="11sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="7.25%"
                                android:textColor="#FFD166"
                                android:textSize="15sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- ISSS chip -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/chip_bg"
                            android:padding="10dp"
                            android:layout_marginEnd="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ISSS"
                                android:textColor="#8892B0"
                                android:textSize="11sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3.00%"
                                android:textColor="#FFD166"
                                android:textSize="15sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Renta chip -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/chip_bg"
                            android:padding="10dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RENTA"
                                android:textColor="#8892B0"
                                android:textSize="11sp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Por tramos"
                                android:textColor="#FFD166"
                                android:textSize="12sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botones acción -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCleanSalary"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Limpiar"
                    android:textColor="#8892B0"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"
                    app:backgroundTint="#1A1D2E"
                    app:strokeColor="#2A3050"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSalaryCalculate"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="2"
                    android:text="Calcular Salario"
                    android:textColor="#0F1117"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="#FFD166"
                    app:cornerRadius="12dp"
                    style="@style/Widget.MaterialComponents.Button"/>

            </LinearLayout>

            <!-- Card: Resultado desglose -->
            <androidx.cardview.widget.CardView
                android:id="@+id/resultCardSal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1D2E"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:alpha="0"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <!-- Nombre empleado resultado -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DESGLOSE SALARIAL"
                        android:textColor="#FFD166"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvResultNameSal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#8892B0"
                        android:textSize="15sp"
                        android:layout_marginBottom="18dp"/>

                    <!-- Fila: Salario base -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <TextView android:id="@+id/labelBase"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Salario Base"
                            android:textColor="#CCD6F6" android:textSize="15sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                        <TextView android:id="@+id/tvResSalarioBase"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#2A3050" android:layout_marginBottom="12dp"/>

                    <!-- Titulo descuentos -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DESCUENTOS"
                        android:textColor="#FF6B6B"
                        android:textSize="11sp"
                        android:letterSpacing="0.10"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <!-- AFP -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView android:id="@+id/labelAFP"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="AFP (7.25%)"
                            android:textColor="#8892B0" android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                        <TextView android:id="@+id/tvResAFP"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="#FF6B6B" android:textSize="14sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- ISSS -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp">
                        <TextView android:id="@+id/labelISSS"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="ISSS (3.00%)"
                            android:textColor="#8892B0" android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                        <TextView android:id="@+id/tvResISSS"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="#FF6B6B" android:textSize="14sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Renta -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">
                        <TextView android:id="@+id/labelRenta"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Renta (por tramos)"
                            android:textColor="#8892B0" android:textSize="14sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                        <TextView android:id="@+id/tvResRenta"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="#FF6B6B" android:textSize="14sp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Total descuentos -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/chip_bg"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total Descuentos"
                            android:textColor="#CCD6F6" android:textSize="14sp" android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                        <TextView android:id="@+id/tvResTotalDesc"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="#FF6B6B" android:textSize="15sp" android:textStyle="bold"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Barra de descuentos -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="% del salario destinado a descuentos"
                        android:textColor="#4A4F6A"
                        android:textSize="11sp"
                        android:layout_marginBottom="6dp"/>

                    <ProgressBar
                        android:id="@+id/progressDiscounts"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="#FF6B6B"
                        android:progressBackgroundTint="#2A2F4A"
                        android:layout_marginBottom="20dp"/>

                    <!-- Divider -->
                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#2A3050" android:layout_marginBottom="16dp"/>

                    <!-- SALARIO NETO grande -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SALARIO NETO"
                        android:textColor="#64FFDA"
                        android:textSize="11sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold"
                        android:layout_gravity="center"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvResNetSalary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#64FFDA"
                        android:textSize="52sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-light"
                        android:layout_gravity="center"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
